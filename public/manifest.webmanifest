{
    "name": "Humi - HR Information System",
    "short_name": "Humi",
    "description": "Portal HRIS untuk karyawan: absensi, cuti, lembur, dan payroll dalam satu aplikasi.",
    "start_url": "/portal",
    "scope": "/",
    "display": "standalone",
    "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
    "background_color": "#006069",
    "theme_color": "#006069",
